{
  "manifest_version": 3,
  "name": "Hack-Quest: The Dungeon Crawler",
  "version": "1.0.0",
  "description": "Your browser tabs are monsters. Fight them in an RPG side panel!",
  "permissions": ["tabs", "storage", "sidePanel"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open Tab-Quest"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}



